@inherits BaseView

@if (IsLoading())
{
    <div class="text-gray-800 text-center">Cargando.... es posible que no tengas sección guiada.</div>
}
else
{
<div class="row">
    <div class="col-xl-12 col-lg-11 mx-auto">
        <div class="card shadow mb-4">
            <div class="card-header py-3 bg-primary">
                <h6 class="m-0 font-weight-bold text-white">
                    <i class="fas fa-file-alt mr-2"></i>Generar Reporte de Notas por Parcial
                </h6>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-4">
                    Selecciona los parciales que deseas incluir en el reporte. El sistema procesará la lista de estudiantes con el ordenamiento requerido (Niñas primero de la A-Z, luego Niños de la A-Z).
                </p>

                @if (Partials == null)
                {
                    <div class="d-flex justify-content-center align-items-center my-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="sr-only">Cargando parciales...</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <div class="card border-left-primary shadow-sm h-100 py-2">
                                <div class="card-body">
                                    <div class="font-weight-bold text-primary text-uppercase mb-3">
                                        I Semestre
                                    </div>
                                    
                                    @foreach (var partial in Partials.Where(p => p.semester == "I Semestre"))
                                    {
                                        <div class="custom-control custom-checkbox mb-2 d-flex align-items-center">
                                            <input type="checkbox" 
                                                   class="custom-control-input" 
                                                   id="chk-@partial.partialId"
                                                   checked="@SelectedPartialIds.Contains(partial.partialId)"
                                                   @onchange="(e) => OnCheckboxChanged(e, partial.partialId)">
                                            <label class="custom-control-label font-weight-bold text-gray-800" for="chk-@partial.partialId">
                                                @partial.label
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 mb-4">
                            <div class="card border-left-success shadow-sm h-100 py-2">
                                <div class="card-body">
                                    <div class="font-weight-bold text-success text-uppercase mb-3">
                                        II Semestre
                                    </div>
                                    
                                    @foreach (var partial in Partials.Where(p => p.semester == "II Semestre"))
                                    {
                                        <div class="custom-control custom-checkbox mb-2 d-flex align-items-center">
                                            <input type="checkbox" 
                                                   class="custom-control-input" 
                                                   id="chk-@partial.partialId"
                                                   checked="@SelectedPartialIds.Contains(partial.partialId)"
                                                   @onchange="(e) => OnCheckboxChanged(e, partial.partialId)">
                                            <label class="custom-control-label font-weight-bold text-gray-800" for="chk-@partial.partialId">
                                                @partial.label
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="sidebar-divider">

                    <div class="d-flex justify-content-end mt-3">
                        <button class="btn btn-primary btn-icon-split shadow-sm" 
                                @onclick="GenerarReporte" 
                                disabled="@(!SelectedPartialIds.Any())">
                            <span class="icon text-white-50">
                                <i class="fas fa-download"></i>
                            </span>
                            <span class="text">Generar Reporte</span>
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
}